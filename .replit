# ============================================================
# CHOICE PROPERTIES — REPLIT SAFETY CONFIGURATION
# ============================================================
# ⚠️  WARNING: This is a STATIC SITE project, NOT a Node.js server.
# 
# This project:
#   ✅ Used ONLY for editing HTML, CSS, JavaScript files
#   ✅ Deployed to Cloudflare Pages (not Replit server)
#   ✅ Backend is Supabase (NOT local database)
#   ✅ Does NOT require npm install, migrations, or auto-run
#
# If Replit tries to auto-run, migrate, or configure:
#   → This is WRONG and will cause errors
#   → DO NOT proceed
#   → Close Replit and re-import from GitHub
#
# See: REPLIT_SAFETY.md for detailed instructions
# ============================================================

# Disable auto-run completely (CRITICAL)
run = ""

# Disable auto-deployment
autoDeploy = false
modules = ["web", "nodejs-18"]

# Disable workflows/run button (CRITICAL)
# This prevents Replit from auto-executing Node.js

[nix]
channel = "stable-25_05"

# Minimal dependencies only (unzip for file handling)
# ✅ NO Node.js, NO databases, NO ORMs, NO package managers

[userenv]
# Store secrets here for LOCAL editing only
# These are NOT pushed to GitHub

[userenv.shared]
